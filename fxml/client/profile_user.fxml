<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="900.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="user.profile_user">
    <children>
        <Pane prefHeight="180.0" prefWidth="900.0" style="-fx-background-color: #0598FF;" />

        <VBox alignment="TOP_CENTER" layoutX="150.0" layoutY="80.0" prefHeight="550.0" prefWidth="600.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 20;">
            <children>
                <StackPane>
                    <Circle fx:id="imageCircle" fill="WHITE" radius="65.0" stroke="#0598FF" strokeType="INSIDE" strokeWidth="2.0" />
                    <ImageView fx:id="profileImageView" fitHeight="120.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true" />
                </StackPane>

                <Button onAction="#handleUploadPhoto" style="-fx-background-color: #0598FF; -fx-text-fill: white; -fx-background-radius: 15;" text="Change Photo">
                    <font> <Font size="11.0" /> </font>
                </Button>

                <Separator prefWidth="200.0" />

                <GridPane hgap="15.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="120.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label text="Full Name:" textFill="#0598FF"> <font><Font name="System Bold" size="14.0" /></font></Label>
                        <TextField fx:id="nameField" style="-fx-border-color: #0598FF; -fx-border-radius: 5;" GridPane.columnIndex="1" />

                        <Label text="Email Address:" textFill="#0598FF" GridPane.rowIndex="1"> <font><Font name="System Bold" size="14.0" /></font></Label>
                        <TextField fx:id="emailField" style="-fx-border-color: #0598FF; -fx-border-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Password:" textFill="#0598FF" GridPane.rowIndex="2"> <font><Font name="System Bold" size="14.0" /></font></Label>
                        <PasswordField fx:id="passwordField" style="-fx-border-color: #0598FF; -fx-border-radius: 5;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label text="Status:" textFill="#0598FF" GridPane.rowIndex="3"> <font><Font name="System Bold" size="14.0" /></font></Label>
                        <Label fx:id="statusLabel" text="Online" textFill="#2ecc71" GridPane.columnIndex="1" GridPane.rowIndex="3">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                    </children>
                    <VBox.margin> <Insets top="10.0" /> </VBox.margin>
                </GridPane>

                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button onAction="#handleSaveChanges" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #0598FF; -fx-text-fill: white; -fx-background-radius: 10;" text="Save Changes" />
                        <Button onAction="#handleLogout" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 10;" text="Logout" />
                    </children>
                    <VBox.margin> <Insets top="20.0" /> </VBox.margin>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>